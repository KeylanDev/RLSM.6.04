<UserControl x:Class="rslm_frontend.Views.SystemInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource VsBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Style="{StaticResource VsToolBarStyle}">
            <Button Style="{StaticResource BlueButtonStyle}" Content="🔄 Refresh" Command="{Binding RefreshCommand}"/>
        </ToolBar>

        <TextBlock Grid.Row="2" Text="Computer Name" Foreground="{StaticResource VsSecondaryTextBrush}" Margin="0,16,0,4"/>
        <TextBlock Grid.Row="3" Text="{Binding ComputerName}" Foreground="{StaticResource VsTextBrush}" FontSize="14"/>

        <TextBlock Grid.Row="4" Text="Username" Foreground="{StaticResource VsSecondaryTextBrush}" Margin="0,16,0,4"/>
        <TextBlock Grid.Row="5" Text="{Binding Username}" Foreground="{StaticResource VsTextBrush}" FontSize="14"/>

        <TextBlock Grid.Row="6" Text="Operating System" Foreground="{StaticResource VsSecondaryTextBrush}" Margin="0,16,0,4"/>
        <TextBlock Grid.Row="7" Text="{Binding OsName}" Foreground="{StaticResource VsTextBrush}" FontSize="14"/>
        <TextBlock Grid.Row="8" Text="{Binding OsVersion}" Foreground="{StaticResource VsSecondaryTextBrush}" FontSize="12" Margin="0,4,0,0"/>

        <TextBlock Grid.Row="9" Text="Architecture" Foreground="{StaticResource VsSecondaryTextBrush}" Margin="0,16,0,4"/>
        <TextBlock Grid.Row="10" Text="{Binding Architecture}" Foreground="{StaticResource VsTextBrush}" FontSize="14"/>

        <TextBlock Grid.Row="11" Text="CPU" Foreground="{StaticResource VsSecondaryTextBrush}" Margin="0,16,0,4"/>
        <TextBlock Grid.Row="12" Text="{Binding CpuCores}" Foreground="{StaticResource VsTextBrush}" FontSize="14"/>

        <TextBlock Grid.Row="13" Text="RAM" Foreground="{StaticResource VsSecondaryTextBrush}" Margin="0,16,0,4"/>
        <StackPanel Grid.Row="14" Orientation="Vertical">
            <TextBlock Text="{Binding TotalRamDisplay}" Foreground="{StaticResource VsTextBrush}" FontSize="14"/>
            <TextBlock Text="{Binding AvailableRamDisplay}" Foreground="{StaticResource VsSecondaryTextBrush}" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="15" Text="GPU" Foreground="{StaticResource VsSecondaryTextBrush}" Margin="0,16,0,4"/>
        <TextBlock Grid.Row="16" Text="{Binding Gpu}" Foreground="{StaticResource VsTextBrush}" FontSize="14" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="17" Text="Is Admin" Foreground="{StaticResource VsSecondaryTextBrush}" Margin="0,16,0,4"/>
        <TextBlock Grid.Row="18" Text="{Binding IsAdmin}" Foreground="{StaticResource VsTextBrush}" FontSize="14"/>
    </Grid>
</UserControl>
