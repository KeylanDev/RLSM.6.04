<UserControl x:Class="rslm_frontend.Views.SystemInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource VsBackgroundBrush}"
             FontFamily="Consolas">

    <UserControl.Resources>
        <!-- Couleurs dnSpy / VS2022 Dark -->
        <SolidColorBrush x:Key="VsBackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="VsPanelBrush" Color="#252526"/>
        <SolidColorBrush x:Key="VsForegroundBrush" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="VsSelectionBrush" Color="#37373D"/>
        <SolidColorBrush x:Key="VsHoverBrush" Color="#2A2D2E"/>
        <SolidColorBrush x:Key="VsBorderBrush" Color="#3F3F46"/>

        <!-- Couleurs syntaxiques -->
        <SolidColorBrush x:Key="VsKeywordBrush" Color="#569CD6"/>
        <SolidColorBrush x:Key="VsValueBrush" Color="#4EC9B0"/>
        <SolidColorBrush x:Key="VsStringBrush" Color="#6A9955"/>
        <SolidColorBrush x:Key="VsNumberBrush" Color="#B5CEA8"/>
        <SolidColorBrush x:Key="VsCommentBrush" Color="#808080"/>
        <SolidColorBrush x:Key="VsAccentBrush" Color="#C586C0"/>
        <SolidColorBrush x:Key="VsFunctionBrush" Color="#DCDCAA"/>
        <SolidColorBrush x:Key="VsConstantBrush" Color="#CE9178"/>

        <!-- Style pour les expanders type dnSpy -->
        <Style TargetType="Expander">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource VsForegroundBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header avec flèche à la dnSpy -->
                            <ToggleButton x:Name="headerToggleButton"
                                          Grid.Row="0"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Cursor="Hand"
                                          HorizontalAlignment="Stretch"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="4,6,4,6">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- Flèche dnSpy : ▶ collapsed, ▼ expanded -->
                                                <TextBlock x:Name="Arrow"
                                                           Text="▶"
                                                           Foreground="{DynamicResource VsForegroundBrush}"
                                                           FontSize="8"
                                                           FontFamily="Segoe UI"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="ArrowRotation" Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <ContentPresenter x:Name="HeaderContent"
                                                                  Content="{Binding Header, RelativeSource={RelativeSource AncestorType=Expander}}"
                                                                  TextElement.FontWeight="SemiBold"
                                                                  TextElement.Foreground="{DynamicResource VsFunctionBrush}"
                                                                  VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource VsHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ToggleButton.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=Expander}}" 
                                                   Foreground="{DynamicResource VsFunctionBrush}"
                                                   FontSize="11"
                                                   FontWeight="Normal"/>
                                    </StackPanel>
                                </ToggleButton.Content>
                            </ToggleButton>

                            <!-- Contenu -->
                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Row="1"
                                              Content="{TemplateBinding Content}"
                                              Margin="16,4,0,8"
                                              Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="contentPresenter" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger SourceName="headerToggleButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="headerToggleButton" Property="Background" Value="{DynamicResource VsHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style pour la toolbar -->
        <Style x:Key="VsToolBarStyle" TargetType="ToolBar">
            <Setter Property="Background" Value="{DynamicResource VsPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource VsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <!-- Style pour les boutons bleus -->
        <Style x:Key="BlueButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource VsAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource VsBackgroundBrush}">
        <StackPanel Margin="12,8,12,8">

            <!-- Toolbar -->
            <ToolBar Style="{StaticResource VsToolBarStyle}" Margin="0,0,0,12">
                <Button Style="{StaticResource BlueButtonStyle}" Content="🔄 Refresh" Command="{Binding RefreshCommand}"/>
            </ToolBar>

            <!-- SYSTEM -->
            <Expander Header="SYSTEM" IsExpanded="True">
                <StackPanel>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Computer Name" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding ComputerName}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Username" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Is Admin" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding IsAdmin}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- NETWORK -->
            <Expander Header="NETWORK" IsExpanded="False">
                <StackPanel>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="IP Address" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding IpAddress}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="MAC Address" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding MacAddress}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hostname" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding ComputerName}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- OPERATING SYSTEM -->
            <Expander Header="OPERATING SYSTEM" IsExpanded="True">
                <StackPanel>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OS" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding OsName}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Version" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding OsVersion}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Architecture" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Architecture}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- HARDWARE -->
            <Expander Header="HARDWARE" IsExpanded="True">
                <StackPanel>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CPU Cores" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding CpuCores}" Foreground="{DynamicResource VsNumberBrush}" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RAM Total" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalRamDisplay}" Foreground="{DynamicResource VsNumberBrush}" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RAM Available" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding AvailableRamDisplay}" Foreground="{DynamicResource VsNumberBrush}" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GPU" Foreground="{DynamicResource VsStringBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Gpu}" Foreground="{DynamicResource VsForegroundBrush}" FontSize="10" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>