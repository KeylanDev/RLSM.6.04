<UserControl x:Class="rslm_frontend.Views.SystemInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource VsBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <ToolBar Style="{StaticResource VsToolBarStyle}" Margin="0,0,0,8">
                <Button Style="{StaticResource BlueButtonStyle}" Content="🔄 Refresh" Command="{Binding RefreshCommand}"/>
            </ToolBar>

            <!-- SYSTEM -->
            <Expander Header="SYSTEM.0.01" IsExpanded="True" Foreground="#C92C2C" FontSize="10" FontWeight="Bold" Margin="0,6">
                <StackPanel Margin="20,8,0,0">
                    <TextBlock Text="Computer Name" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding ComputerName}" Foreground="#D6BE24" FontSize="10" Margin="0,0,0,12"/>
                    <TextBlock Text="Username" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding Username}" Foreground="#D6BE24" FontSize="10" Margin="0,0,0,12"/>
                    <TextBlock Text="Is Admin" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding IsAdmin}" Foreground="#D6BE24" FontSize="10"/>
                </StackPanel>
            </Expander>

            <!-- NETWORK -->
            <Expander Header="NETWORK.0.02" IsExpanded="False" Foreground="#C92C2C" FontSize="10" FontWeight="Light" Margin="0,6">
                <StackPanel Margin="20,8,0,0">
                    <TextBlock Text="IP Address" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding IpAddress}" Foreground="#D6BE24" FontSize="10" Margin="0,0,0,12"/>
                    <TextBlock Text="MAC Address" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding MacAddress}" Foreground="#D6BE24" FontSize="10" Margin="0,0,0,12"/>
                    <TextBlock Text="Hostname" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding ComputerName}" Foreground="#D6BE24" FontSize="10"/>
                </StackPanel>
            </Expander>

            <!-- OS -->
            <Expander Header="OPERATING.SYSTEM.0.03" IsExpanded="True" Foreground="#CE9178" FontSize="10" FontWeight="Light" Margin="0,6">
                <StackPanel Margin="20,8,0,0">
                    <TextBlock Text="OS" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding OsName}" Foreground="#D6BE24" FontSize="10" Margin="0,0,0,12"/>
                    <TextBlock Text="Version" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding OsVersion}" Foreground="#D6BE24" FontSize="10" Margin="0,0,0,12"/>
                    <TextBlock Text="Architecture" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding Architecture}" Foreground="#D6BE24" FontSize="10"/>
                </StackPanel>
            </Expander>

            <!-- HARDWARE -->
            <Expander Header="HARDWARE.0.04" IsExpanded="True" Foreground="#CE9178" FontSize="14" FontWeight="Light" Margin="0,6">
                <StackPanel Margin="20,8,0,0">
                    <TextBlock Text="CPU Cores" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding CpuCores}" Foreground="#D6BE24" FontSize="11" Margin="0,0,0,12"/>
                    <TextBlock Text="RAM Total" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding TotalRamDisplay}" Foreground="#D6BE24" FontSize="10" Margin="0,0,0,12"/>
                    <TextBlock Text="RAM Available" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding AvailableRamDisplay}" Foreground="#D6BE24" FontSize="10" Margin="0,0,0,12"/>
                    <TextBlock Text="GPU" Foreground="#42A624" FontSize="5"/>
                    <TextBlock Text="{Binding Gpu}" Foreground="#D6BE24" FontSize="10" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>