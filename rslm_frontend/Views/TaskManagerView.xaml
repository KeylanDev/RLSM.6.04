<UserControl x:Class="rslm_frontend.Views.TaskManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource VsBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Style="{DynamicResource VsToolBarStyle}">
            <Button Style="{DynamicResource BlueButtonStyle}" Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}" ToolTip="Refresh process list"/>
            <Separator Style="{DynamicResource VsToolBarSeparatorStyle}"/>
            <Button Style="{DynamicResource RedButtonStyle}" Content="❌ Kill Process"
                    Command="{Binding KillCommand}" ToolTip="Kill selected process"/>
            <Separator Style="{DynamicResource VsToolBarSeparatorStyle}"/>
            <TextBlock Margin="8,0,4,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource VsSecondaryTextBrush}"
                       Text="Search:"/>
            <TextBox Width="200" Height="22" 
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="#3E3E42" Foreground="#CCCCCC" 
                     BorderBrush="#555555" BorderThickness="1" Padding="5,2"/>
            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource VsSecondaryTextBrush}"
                       Text="{Binding StatusText}"/>
        </ToolBar>

        <ListView Grid.Row="1" x:Name="TasksListView"
                  ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                  Background="#FF1E1E1E"
                  Foreground="{DynamicResource VsTextBrush}"
                  BorderBrush="{DynamicResource VsBorderBrush}"
                  BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="PID" DisplayMemberBinding="{Binding Pid}" Width="100"/>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="250"/>
                    <GridViewColumn Header="Memory" DisplayMemberBinding="{Binding MemoryDisplay}" Width="100"/>
                    <GridViewColumn Header="Threads" DisplayMemberBinding="{Binding Threads}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StatusBar Grid.Row="2" Background="{DynamicResource VsPanelBrush}">
            <StatusBarItem>
                <TextBlock Foreground="{DynamicResource VsSecondaryTextBrush}"
                           Text="{Binding TargetAgentId, StringFormat='Agent: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
