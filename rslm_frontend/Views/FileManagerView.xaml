
<UserControl x:Class="rslm_frontend.Views.FileManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource VsBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <ToolBar Grid.Row="0" Style="{StaticResource VsToolBarStyle}">
            <Button Style="{StaticResource StandardButtonStyle}" Content="Parent .." Command="{Binding ParentCommand}"/>
            <Button Style="{StaticResource BlueButtonStyle}" Content="🔄 Refresh" Command="{Binding RefreshCommand}"/>
            <Separator Style="{StaticResource VsToolBarSeparatorStyle}"/>
            <Button Style="{StaticResource StandardButtonStyle}" Content="📥 Download" Command="{Binding DownloadCommand}"/>
            <Button Style="{StaticResource RedButtonStyle}" Content="❌ Delete" Command="{Binding DeleteCommand}"/>
            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource VsSecondaryTextBrush}" Text="{Binding StatusText}"/>
        </ToolBar>
        
        <Border Grid.Row="1" Background="#252526" Padding="6">
            <TextBox x:Name="PathTextBox"
                     Text="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}"
                     Background="#1E1E1E"
                     Foreground="{StaticResource VsTextBrush}"
                     BorderBrush="{StaticResource VsBorderBrush}"
                     BorderThickness="1"
                     Padding="6"
                     PreviewKeyDown="PathTextBox_PreviewKeyDown"/>
        </Border>
        
        <ListView Grid.Row="2" x:Name="FilesListView"
                  ItemsSource="{Binding Files}"
                  SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                  Background="#1E1E1E"
                  Foreground="{StaticResource VsTextBrush}"
                  BorderBrush="{StaticResource VsBorderBrush}"
                  BorderThickness="1"
                  MouseDoubleClick="FilesListView_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="300"/>
                    <GridViewColumn Header="Size" DisplayMemberBinding="{Binding SizeDisplay}" Width="120"/>
                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
        
        <StatusBar Grid.Row="3" Style="{StaticResource VsStatusBarStyle}">
            <StatusBarItem Style="{StaticResource VsStatusBarItemStyle}">
                <TextBlock Text="{Binding TargetAgentId, StringFormat='Machine: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
