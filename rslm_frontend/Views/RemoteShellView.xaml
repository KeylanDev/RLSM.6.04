<UserControl x:Class="rslm_frontend.Views.RemoteShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource VsBackgroundBrush}"
             Focusable="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Style="{DynamicResource VsToolBarStyle}">
            <Button Style="{DynamicResource GreenButtonStyle}" Content="▶ Open" Command="{Binding OpenShellCommand}" ToolTip="Open Remote Shell"/>
            <Button Style="{DynamicResource RedButtonStyle}" Content="■ Close" Command="{Binding CloseShellCommand}" ToolTip="Close Remote Shell"/>
            <Button Style="{DynamicResource StandardButtonStyle}" Content="Clear" Command="{Binding ClearCommand}" ToolTip="Clear Terminal Output"/>
            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource VsSecondaryTextBrush}" Text="{Binding StatusText}"/>
        </ToolBar>

        <Border Grid.Row="1" BorderBrush="#FF2D2D30" BorderThickness="1" Background="#0C0C0D">
            <TextBox x:Name="ShellOutput"
                     IsReadOnly="True"
                     Background="#0C0C0D"
                     Foreground="#C0C0C0"
                     FontFamily="Consolas"
                     FontSize="13"
                     BorderThickness="0"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Padding="8"/>
        </Border>

        <Grid Grid.Row="2" Background="#FF1A1A1A" Margin="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Margin="8,6,4,6"
                       VerticalAlignment="Center"
                       Foreground="#FF33FF33"
                       FontFamily="Consolas"
                       FontSize="13"
                       Text="{Binding Prompt}"/>
            <TextBox x:Name="InputBox"
                     Grid.Column="1"
                     Margin="0,4,8,4"
                     Background="#0C0C0D"
                     Foreground="#C0C0C0"
                     CaretBrush="#C0C0C0"
                     BorderBrush="#FF2D2D30"
                     FontFamily="Consolas"
                     FontSize="13"
                     Padding="4,2"
                     Text="{Binding InputLine, UpdateSourceTrigger=PropertyChanged}"
                     PreviewKeyDown="InputBox_PreviewKeyDown"/>
        </Grid>

        <StatusBar Grid.Row="3" Background="{DynamicResource VsPanelBrush}">
            <StatusBarItem Style="{DynamicResource VsStatusBarItemStyle}">
                <TextBlock Text="{Binding TargetAgentId, StringFormat='Machine: {0}'}"/>
            </StatusBarItem>
            <StatusBarItem Style="{DynamicResource VsStatusBarItemStyle}">
                <TextBlock Text="{Binding IsShellOpen, StringFormat='Shell: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
