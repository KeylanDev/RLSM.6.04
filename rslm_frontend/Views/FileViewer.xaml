<UserControl x:Class="rslm_frontend.Views.FileViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E"
             FontFamily="Consolas">

    <UserControl.Resources>
        <SolidColorBrush x:Key="VsBackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="VsPanelBrush" Color="#252526"/>
        <SolidColorBrush x:Key="VsForegroundBrush" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="VsSelectionBrush" Color="#37373D"/>
        <SolidColorBrush x:Key="VsBorderBrush" Color="#3F3F46"/>

        <!-- Couleurs syntaxiques -->
        <SolidColorBrush x:Key="VsKeywordBrush" Color="#569CD6"/>
        <SolidColorBrush x:Key="VsStringBrush" Color="#6A9955"/>
        <SolidColorBrush x:Key="VsNumberBrush" Color="#B5CEA8"/>
        <SolidColorBrush x:Key="VsCommentBrush" Color="#808080"/>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource VsBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource VsPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource VsForegroundBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource VsBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource VsSelectionBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource VsForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource VsSelectionBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="{StaticResource VsPanelBrush}" Padding="4,2">
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding SaveCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾" Margin="0,0,4,0"/>
                    <TextBlock Text="Save"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ZoomInCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍+" Margin="0,0,4,0"/>
                    <TextBlock Text="Zoom In"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ZoomOutCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍-" Margin="0,0,4,0"/>
                    <TextBlock Text="Zoom Out"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ZoomResetCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="↺" Margin="0,0,4,0"/>
                    <TextBlock Text="Reset"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- Contenu : Texte, Image ou Hexa -->
        <Grid Grid.Row="1" Margin="2">
            <ScrollViewer x:Name="TextScrollViewer" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{StaticResource VsBackgroundBrush}">
                <TextBox x:Name="TextEditor" 
                         Background="{StaticResource VsBackgroundBrush}"
                         Foreground="{StaticResource VsForegroundBrush}"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </ScrollViewer>

            <ScrollViewer x:Name="ImageScrollViewer" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{StaticResource VsBackgroundBrush}"
                          CanContentScroll="True">
                <Border Background="{StaticResource VsBackgroundBrush}">
                    <Image x:Name="ImageViewer" 
                           Stretch="Uniform"
                           MaxWidth="1200"
                           MaxHeight="800"
                           Source="{Binding ImageSource}"/>
                </Border>
            </ScrollViewer>

            <ScrollViewer x:Name="HexScrollViewer" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{StaticResource VsBackgroundBrush}">
                <TextBox x:Name="HexEditor" 
                         Background="{StaticResource VsBackgroundBrush}"
                         Foreground="{StaticResource VsNumberBrush}"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="11"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"/>
            </ScrollViewer>

            <TextBlock x:Name="LoadingText" 
                       Text="Loading file..."
                       Foreground="{StaticResource VsCommentBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Visible"/>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource VsPanelBrush}" Padding="4,2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" 
                           Text="Ready" 
                           Foreground="{StaticResource VsForegroundBrush}"
                           FontFamily="Consolas"
                           FontSize="10"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="FileInfoText" 
                           Text=""
                           Foreground="{StaticResource VsCommentBrush}"
                           FontFamily="Consolas"
                           FontSize="10"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>