<UserControl x:Class="rslm_frontend.Views.RegistryEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource VsBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ToolBar Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource VsToolBarStyle}">
            <Button Style="{StaticResource BlueButtonStyle}" Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}" ToolTip="Refresh values"/>
            <Separator Style="{StaticResource VsToolBarSeparatorStyle}"/>
            <Button Style="{StaticResource RedButtonStyle}" Content="❌ Delete Value"
                    Command="{Binding DeleteValueCommand}" ToolTip="Delete selected value"/>
            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                       Foreground="{StaticResource VsSecondaryTextBrush}"
                       Text="{Binding StatusText}"/>
        </ToolBar>

        <TreeView Grid.Row="1" Grid.Column="0"
                  ItemsSource="{Binding RootKeys}"
                  SelectedItemChanged="TreeView_SelectedItemChanged"
                  Background="#FF1E1E1E"
                  Foreground="{StaticResource VsTextBrush}"
                  BorderBrush="{StaticResource VsBorderBrush}"
                  BorderThickness="1">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding}">
                    <TextBlock Text="{Binding Name}"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <ListView Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding Values}"
                  SelectedItem="{Binding SelectedValue, Mode=TwoWay}"
                  Background="#FF1E1E1E"
                  Foreground="{StaticResource VsTextBrush}"
                  BorderBrush="{StaticResource VsBorderBrush}"
                  BorderThickness="1"
                  Margin="4,0,0,0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="150"/>
                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="100"/>
                    <GridViewColumn Header="Data" DisplayMemberBinding="{Binding Data}" Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StatusBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource VsPanelBrush}">
            <StatusBarItem>
                <TextBlock Foreground="{StaticResource VsSecondaryTextBrush}"
                           Text="{Binding TargetAgentId, StringFormat='Agent: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
