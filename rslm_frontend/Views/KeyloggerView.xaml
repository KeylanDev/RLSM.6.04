<UserControl x:Class="rslm_frontend.Views.KeyloggerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource VsBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Style="{DynamicResource VsToolBarStyle}">
            <Button Style="{DynamicResource GreenButtonStyle}" Content="▶ Start"
                    Command="{Binding StartCommand}" ToolTip="Start keylogger"/>
            <Button Style="{DynamicResource RedButtonStyle}" Content="⏹ Stop"
                    Command="{Binding StopCommand}" ToolTip="Stop keylogger"/>
            <Separator Style="{DynamicResource VsToolBarSeparatorStyle}"/>
            <Button Style="{DynamicResource StandardButtonStyle}" Content="🗑 Clear"
                    Command="{Binding ClearCommand}" ToolTip="Clear logs"/>
            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource VsSecondaryTextBrush}"
                       Text="{Binding StatusText}"/>
        </ToolBar>

        <Border Grid.Row="1" BorderBrush="{DynamicResource VsBorderBrush}" BorderThickness="1" Background="{DynamicResource VsBackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="LogTextBox" 
                         IsReadOnly="True"
                         Background="{DynamicResource VsBackgroundBrush}" 
                         Foreground="{DynamicResource VsTextBrush}"
                         FontFamily="Consolas" 
                         FontSize="12"
                         Padding="8" 
                         BorderThickness="0"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Visible"/>
            </ScrollViewer>
        </Border>

        <StatusBar Grid.Row="2" Background="{DynamicResource VsPanelBrush}">
            <StatusBarItem>
                <TextBlock Foreground="{DynamicResource VsSecondaryTextBrush}"
                           Text="{Binding TargetAgentId, StringFormat='Agent: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>