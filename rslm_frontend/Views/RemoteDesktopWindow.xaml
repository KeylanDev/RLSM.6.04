<Window x:Class="rslm_frontend.Views.RemoteDesktopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Desktop"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Topmost="True"
        Width="800"
        Height="600"
        FontFamily="Segoe UI"
        FontSize="11">
    <Border BorderBrush="#7B2D8E" BorderThickness="2" Background="#1E1E1E" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#2D2D30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Remote Desktop" Foreground="#7B2D8E" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold"/>
                <Button Content="✕" Foreground="#AAAAAA" Background="Transparent" BorderThickness="0"
                        Width="40" Height="30" HorizontalAlignment="Right" Click="CloseButton_Click"/>
            </Grid>
            <ContentPresenter Grid.Row="1" Name="ViewContent"/>
        </Grid>
    </Border>
</Window>
