<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="VsBackground">#1E1E1E</Color>
    <Color x:Key="VsPanel">#252526</Color>
    <Color x:Key="VsBorder">#2D2D30</Color>
    <Color x:Key="VsText">#D4D4D4</Color>
    <Color x:Key="VsSecondaryText">#9D9D9D</Color>
    <Color x:Key="VsAccent">#7B2D8E</Color>
    <Color x:Key="VsHover">#2A2D2E</Color>
    <Color x:Key="VsSelection">#264F78</Color>

    <Color x:Key="VsLightBackground">#F5F5F5</Color>
    <Color x:Key="VsLightPanel">#FFFFFF</Color>
    <Color x:Key="VsLightBorder">#D0D0D0</Color>
    <Color x:Key="VsLightText">#202020</Color>
    <Color x:Key="VsLightSecondaryText">#666666</Color>
    <Color x:Key="VsLightAccent">#7B2D8E</Color>
    <Color x:Key="VsLightHover">#E8E8E8</Color>
    <Color x:Key="VsLightSelection">#E0E0E0</Color>

    <SolidColorBrush x:Key="VsBackgroundBrush" Color="{StaticResource VsBackground}" />
    <SolidColorBrush x:Key="VsPanelBrush" Color="{StaticResource VsPanel}" />
    <SolidColorBrush x:Key="VsBorderBrush" Color="{StaticResource VsBorder}" />
    <SolidColorBrush x:Key="VsTextBrush" Color="{StaticResource VsText}" />
    <SolidColorBrush x:Key="VsSecondaryTextBrush" Color="{StaticResource VsSecondaryText}" />
    <SolidColorBrush x:Key="VsAccentBrush" Color="{StaticResource VsAccent}" />
    <SolidColorBrush x:Key="VsHoverBrush" Color="{StaticResource VsHover}" />
    <SolidColorBrush x:Key="VsSelectionBrush" Color="{StaticResource VsSelection}" />

    <SolidColorBrush x:Key="VsLightBackgroundBrush" Color="{StaticResource VsLightBackground}" />
    <SolidColorBrush x:Key="VsLightPanelBrush" Color="{StaticResource VsLightPanel}" />
    <SolidColorBrush x:Key="VsLightBorderBrush" Color="{StaticResource VsLightBorder}" />
    <SolidColorBrush x:Key="VsLightTextBrush" Color="{StaticResource VsLightText}" />
    <SolidColorBrush x:Key="VsLightSecondaryTextBrush" Color="{StaticResource VsLightSecondaryText}" />
    <SolidColorBrush x:Key="VsLightAccentBrush" Color="{StaticResource VsLightAccent}" />
    <SolidColorBrush x:Key="VsLightHoverBrush" Color="{StaticResource VsLightHover}" />
    <SolidColorBrush x:Key="VsLightSelectionBrush" Color="{StaticResource VsLightSelection}" />

    <FontFamily x:Key="VsUIFont">Segoe UI</FontFamily>
    <FontFamily x:Key="VsMonoFont">Consolas</FontFamily>

    <BooleanToVisibilityConverter x:Key="VsVisibilityConverter" />

    <Style x:Key="VsToolBarStyle" TargetType="ToolBar">
        <Setter Property="Background" Value="{DynamicResource VsBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource VsTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource VsBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style x:Key="BlueButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource VsAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.85" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StandardButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="#3E3E42" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#4F4F53" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RedButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="#F44336" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#EF5350" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GreenButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="#4CAF50" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#66BB6A" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="VsToolBarSeparatorStyle" TargetType="Separator">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="Background" Value="{DynamicResource VsBorderBrush}" />
    </Style>

</ResourceDictionary>